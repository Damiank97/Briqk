{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/voorwaarden",
      "destination": "/algemene-voorwaarden.html"
    },
    {
      "source": "/blog-ai-voor-mkb",
      "destination": "/blog-ai-voor-mkb.html"
    },
    {
      "source": "/blog/ai-automatisering-mkb",
      "destination": "/blog-ai-automatisering-mkb.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}